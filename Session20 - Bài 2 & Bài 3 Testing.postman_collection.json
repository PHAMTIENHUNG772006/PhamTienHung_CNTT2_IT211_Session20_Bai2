      "item": [
        {
          "name": "1. Đăng ký tài khoản mới",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"hungptit_b2\",\n    \"password\": \"password123\",\n    \"email\": \"hung_b2@stu.ptit.edu.vn\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/tasks/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "tasks",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2. Đăng nhập hệ thống",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.access_token) {",
                  "    pm.globals.set(\"b2_access_token\", jsonData.access_token);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"hungptit_b2\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/tasks/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "tasks",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "3. Lấy danh sách Task (Stream API lọc PENDING)",
